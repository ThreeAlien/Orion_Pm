# ============================================================
# Orion PM — environment variables
# 部署時複製到 Vercel project settings → Environment Variables
# ============================================================

# PostgreSQL connection — production 用 Neon free tier
# 例：postgresql://user:pass@ep-xxx.aws.neon.tech/orion?sslmode=require
DATABASE_URL=""

# Auth.js v5
# AUTH_SECRET 用 `openssl rand -base64 32` 產一條新的，不要沿用 dev 那條
AUTH_SECRET=""
AUTH_TRUST_HOST="true"

# Google OAuth — Cloud Console 拿 Client ID / Secret
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# 白名單：Google 登入只允許這些 email，逗號分隔，大小寫不敏感
# 之後加人改這條 env 即可，不用動 code
ALLOWED_EMAILS=""
